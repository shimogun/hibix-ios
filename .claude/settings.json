{
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Bash(swift build:*)",
      "Bash(swift test:*)",
      "Bash(swift package resolve)",
      "Bash(swift package update)",
      "Bash(swift package show-dependencies)",
      "Bash(xcodebuild build -scheme Hibix -destination *)",
      "Bash(xcodebuild test -scheme Hibix -destination *)",
      "Bash(xcodebuild clean -scheme Hibix)",
      "Bash(xcrun simctl list)",
      "Bash(xcrun simctl boot *)",
      "Bash(xcrun simctl shutdown *)",
      "Bash(swift format --in-place *)",
      "Bash(swiftformat *)",
      "Bash(swiftlint lint *)",
      "Bash(swiftlint --fix *)",
      "Bash(sqlite3 *.sqlite *)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git restore:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)"
    ],
    "deny": [
      "Bash(xcodebuild archive *)",
      "Bash(xcodebuild -exportArchive *)",
      "Bash(xcrun altool *)",
      "Bash(xcrun notarytool *)",
      "Bash(fastlane *)",
      "Bash(security *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "WebFetch"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.swift ]]; then swiftformat \"$CLAUDE_FILE_PATH\" >/dev/null 2>&1 && swiftlint lint --quiet \"$CLAUDE_FILE_PATH\" 2>&1 || true; fi"
          }
        ]
      }
    ]
  }
}
